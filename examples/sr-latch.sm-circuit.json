{
  "name": "sr_latch",
  "description": "Set-Reset latch using cross-coupled NOR gates",
  "version": "1.0.0",
  "inputs": ["SET", "RESET"],
  "outputs": ["Q", "Q_bar"],
  "gates": [
    { "id": "nor1", "type": "nor", "inputs": ["RESET", "Q_bar"], "output": "Q" },
    { "id": "nor2", "type": "nor", "inputs": ["SET", "Q"], "output": "Q_bar" }
  ]
}